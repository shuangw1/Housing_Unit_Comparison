gdb = r"C:\Documents\ArcGIS\Projects\create_comparison\create_comparison.gdb"
arcpy.env.workspace = gdb
arcpy.env.overwriteOutput = True


# Input data
all_pts   = os.path.join(gdb, "Housing_Units_Points_2025")     # BEFORE spatial join
final_pts = os.path.join(gdb, "Parcel_Housing_withBG_2025")    # AFTER spatial join

# 1) Select the two PINs from the full points
sel_query = "PIN IN ('0502 13  0024','0513 02  0133A')"
arcpy.management.MakeFeatureLayer(all_pts, "exc_lyr", sel_query)

# 2) Copy them to a temp feature class
exceptions_fc = os.path.join(gdb, "Exceptions_ManualBG")
arcpy.management.CopyFeatures("exc_lyr", exceptions_fc)

# 3) Make sure CENSU_ID field exists
if "CENSU_ID" not in [f.name for f in arcpy.ListFields(exceptions_fc)]:
    arcpy.management.AddField(exceptions_fc, "CENSU_ID", "TEXT", field_length=12)


# 4) Manually assign correct block group IDs
pin_to_bg = {
    "0502 13  0024": "510594503003",
    "0513 02  0133A": "510594503004"
}

with arcpy.da.UpdateCursor(exceptions_fc, ["PIN", "CENSU_ID"]) as cur:
    for row in cur:
        if row[0] in pin_to_bg:
            row[1] = pin_to_bg[row[0]]
            cur.updateRow(row)

# 5) Append corrected points into the final spatial join output
arcpy.management.Append(inputs=exceptions_fc, target=final_pts, schema_type="NO_TEST")

print("Done. Exceptions manually appended to Parcel_Housing_withBG_2025")

