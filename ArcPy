# 1) Build SQL with a synthetic OID using ROW_NUMBER()
sql = f"""
SELECT
  ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS OID,
  *
FROM {schema_tbl}
WHERE VALID_TO > '2024-12-31' AND VALID_TO <= '2025-01-01'
"""

# 2) Make a Query Layer using the synthetic OID
qlayer = "hu_qry_layer"
arcpy.management.MakeQueryLayer(sde_conn, qlayer, sql, "OID")

# 3) Export to GDB
