print(f"Done at {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}. Wrote: {out_tbl}")



### Add Lat and Lon to parcel centroids ------------------------------------------------------------------------------
fc1 = r"C:\Documents\ArcGIS\Projects\create_comparison\create_comparison.gdb\Parcel_Centroids_2025"

arcpy.env.overwriteOutput = True

# Add fields if missing
existing = {f.name.lower() for f in arcpy.ListFields(fc1)}
if "lon" not in existing:
    arcpy.management.AddField(fc1, "lon", "DOUBLE")
if "lat" not in existing:
    arcpy.management.AddField(fc1, "lat", "DOUBLE")

# Calculate longitude/latitude in NAD83 (decimal degrees)
nad83_geo = arcpy.SpatialReference(4269)  # GCS_North_American_1983
arcpy.management.CalculateGeometryAttributes(
    in_features=fc1,
    geometry_property=[["lon", "POINT_X"], ["lat", "POINT_Y"]],
    coordinate_system=nad83_geo,
    coordinate_format="DD"
)

print("Done. lon/lat populated in NAD83 decimal degrees.")



### Join parcel centroids to housing units using PIN, keep structure of housing unit table------------------------------------

gdb = r"C:\Documents\ArcGIS\Projects\create_comparison\create_comparison.gdb"
arcpy.env.workspace = gdb
arcpy.env.overwriteOutput = True

# Inputs
parcel_fc   = os.path.join(gdb, "Parcel_Centroids_2025")   # feature class WITH fields: lon, lat (decimal degrees)
housing_tbl = os.path.join(gdb, "Housing_Units_2025")      # table (no geometry; has PIN)

# Join parcel coords onto housing table (keeps housing row count)

# This copies lon/lat *into* the housing table by PIN
arcpy.management.JoinField(
    in_data=housing_tbl, 
    in_field="PIN",
    join_table=parcel_fc, 
    join_field="PIN"
    # Note: no 'fields' argument → brings ALL non-geometry fields
)

# 2) Create a point feature class from housing table using the joined lon/lat
out_points = os.path.join(gdb, "Housing_Units_Points_2025")

# Choose the coordinate system that matches lon/lat:
# - If lon/lat are in WGS84 → use 4326
# - If lon/lat are in NAD83 geographic → use 4269
spref = arcpy.SpatialReference(4269)  # WGS84; change to 4269 if you calculated in NAD83

arcpy.management.XYTableToPoint(
    in_table=housing_tbl,
    out_feature_class=out_points,
    x_field="lon",
    y_field="lat",
    coordinate_system=spref
)

print(f"Done. Wrote: {out_points}")



